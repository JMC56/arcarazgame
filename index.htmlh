<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>ARCARAZ GAME</title>

<style>
@font-face {
  font-family: 'Minecraft';
  src: url('assets/fonts/Minecraft.ttf') format('truetype');
}

*{
  margin:0;
  padding:0;
  box-sizing:border-box;
}

body{
  background: radial-gradient(circle at center, #001133, #000);
  height:100vh;
  display:flex;
  align-items:center;
  justify-content:center;
  flex-direction:column;
  overflow:hidden;
  font-family:'Minecraft', monospace;
}

/* FONDO PIXEL */
body::before{
  content:'';
  position:absolute;
  width:200%;
  height:200%;
  background:
    radial-gradient(circle, rgba(0,150,255,0.15) 1px, transparent 1px);
  background-size:25px 25px;
  animation:move 10s linear infinite;
}

@keyframes move{
  from{transform:translate(0,0);}
  to{transform:translate(-50px,-50px);}
}

/* TITULO */
.title{
  text-align:center;
  margin-bottom:40px;
}

.title .main{
  font-size:120px;
  color:#00eaff;
  text-shadow:
    5px 5px 0 #000,
    10px 10px 0 #002244,
    0 0 20px #00eaff,
    0 0 40px #0077ff,
    0 0 80px #0044ff;
  letter-spacing:6px;
}

/* SUBTITULO */
.title .sub{
  font-size:50px;
  color:#66ffff;
  margin-top:10px;
  text-shadow:
    3px 3px 0 #000,
    0 0 15px #00ccff,
    0 0 30px #0077ff;
}

/* BOTONES PIXEL */
.buttons{
  display:flex;
  gap:20px;
  align-items:center;
  margin-bottom:20px;
}

.btn{
  padding:16px 30px;
  font-size:18px;
  border:none;
  font-family:'Minecraft';
  letter-spacing:2px;
  cursor:default;
}

/* JUEGA */
.juega{
  background:#2ecc71;
  color:white;
  box-shadow:
    4px 4px 0 #0a3d1f,
    0 0 10px #00ff88;
}

/* SUFRE */
.sufre{
  background:#e74c3c;
  color:white;
  box-shadow:
    4px 4px 0 #3d0a0a,
    0 0 10px #ff0000;
}

/* NUMERO */
.middle{
  font-size:25px;
  color:#ffd000;
  text-shadow:0 0 10px #ffd000;
}

/* FECHA */
.date{
  font-size:22px;
  color:#ff9900;
  margin-top:10px;
  text-shadow:0 0 10px #ff9900;
}

/* TEXTO FINAL */
.bottom{
  margin-top:10px;
  font-size:14px;
  color:#ccc;
  letter-spacing:3px;
}
</style>

</head>
<body>

<div class="title">
  <div class="main">ARCARAZ</div>
  <div class="sub">GAME</div>
</div>

<div class="buttons">
  <div class="btn juega">JUEGA</div>
  <div class="middle">0</div>
  <div class="btn sufre">SUFRE</div>
</div>

<div class="date">31 . 03 . 26</div>

<div class="bottom">
  EL JUEGO SE DESBLOQUEA EN
</div>

</body>
</html>
